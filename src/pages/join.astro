---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import siteConfig from "@/content/site.yaml";

const email = siteConfig.contact?.email;
---

<Layout
  title="Join the lab | Grosenick Lab"
  description="The Grosenick Lab at Weill Cornell Medicine is recruiting postdocs, PhD students, and research associates in machine learning, neuroengineering, and clinical neuroscience."
>
  <PageHeader
    eyebrow="Join us"
    title="The lab is hiring."
    lead="Open to postdocs, PhD students, MD-PhD candidates, and research associates across machine learning, neuroengineering, and clinical neuroscience. Email the PI to start a conversation."
  />

  <div class="mx-auto max-w-[1120px] px-7 py-16">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <p
          class="font-mono text-xs uppercase tracking-[0.16em] text-signal-ink m-0 mb-3"
        >
          Who we look for
        </p>
        <h2 class="font-display text-[24px] font-medium tracking-[-0.01em] m-0 mb-4">
          People willing to learn outside their home field.
        </h2>
        <p class="text-muted text-[17px] leading-[1.65] m-0 mb-4">
          The lab works best when methods people get curious about clinical
          questions, and when clinicians get curious about how the methods
          actually work. You don't need to know everything coming in; you do
          need to be willing to read papers in a discipline that isn't yours.
        </p>
        <ul
          class="text-muted text-[16.5px] leading-[1.65] list-disc pl-5 m-0 space-y-2"
        >
          <li>
            <strong class="text-ink font-semibold">Postdocs</strong> trained in
            ML, statistics, or systems neuroscience, looking to work on
            psychiatric problems.
          </li>
          <li>
            <strong class="text-ink font-semibold">PhD students</strong> in
            Neuroscience, the Tri-I MD-PhD program, BCMB, Biostatistics, or
            applied math, looking for thesis work in machine learning on
            clinical data.
          </li>
          <li>
            <strong class="text-ink font-semibold">Research associates</strong>
            and MD-PhD trainees interested in TMS-EEG, multimodal clinical
            data, and computational psychiatry.
          </li>
        </ul>
      </div>

      <div>
        <p
          class="font-mono text-xs uppercase tracking-[0.16em] text-signal-ink m-0 mb-3"
        >
          What you get
        </p>
        <h2 class="font-display text-[24px] font-medium tracking-[-0.01em] m-0 mb-4">
          Clinical data, collaborators, and mentorship aimed at your career.
        </h2>
        <ul
          class="text-muted text-[16.5px] leading-[1.65] list-disc pl-5 m-0 space-y-2"
        >
          <li>
            Collaborations across Weill Cornell Psychiatry, Neuroscience, and
            Engineering. Access to clinical cohorts and TMS-EEG infrastructure.
          </li>
          <li>
            Lab alumni have gone to faculty positions and to roles at
            Anthropic, Nvidia, BCG, and top PhD/MD programs. See <a
              href="/people/#alumni"
              class="text-signal-ink hover:underline">where alumni went</a
            >.
          </li>
          <li>
            Funded by NIMH, NIH ORIP, Simons, Whitehall, Wellcome Leap, and
            others. See <a
              href="/#software"
              class="text-signal-ink hover:underline">our software</a
            > and <a
              href="/publications/"
              class="text-signal-ink hover:underline">publications</a
            > for the kind of work.
          </li>
          <li>
            Mentorship aimed at your career: first-author papers, conference
            funding, and grant-writing support.
          </li>
        </ul>
      </div>
    </div>

    <section class="mt-20 pt-14 border-t border-line">
      <p
        class="font-mono text-xs uppercase tracking-[0.16em] text-signal-ink m-0 mb-3"
      >
        How to apply
      </p>
      <h2
        class="font-display text-[26px] md:text-[28px] font-medium tracking-[-0.015em] m-0 mb-4 max-w-[40ch]"
      >
        Reach out. The lab handles each application directly.
      </h2>
      <p class="text-muted text-[17px] leading-[1.65] max-w-[62ch] m-0 mb-7">
        Email <a
          href={`mailto:${email}`}
          class="text-signal-ink font-medium hover:underline">{email}</a
        > with a short note about what you want to work on, your CV, and (for
        postdocs) one or two representative papers. PhD applicants should apply
        through the relevant graduate program at Weill Cornell or Cornell, and
        email directly so we know to look for the application.
      </p>
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-ink text-paper font-display font-medium text-sm no-underline hover:bg-signal-ink transition-colors"
      >
        Email the PI
      </a>
    </section>
  </div>
</Layout>
