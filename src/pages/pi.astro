---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { Content, frontmatter } from "@/content/pi.md";
import { publicAssetExists } from "@/lib/assets";

const showPhoto = publicAssetExists(frontmatter.photo);
const initials = frontmatter.name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((t: string) => t.charAt(0).toUpperCase())
  .join("");

const linkRows: Array<{ label: string; href: string }> = [
  frontmatter.links?.cv ? { label: "CV (PDF)", href: frontmatter.links.cv } : null,
  frontmatter.links?.scholar ? { label: "Google Scholar", href: frontmatter.links.scholar } : null,
  frontmatter.links?.ncbi ? { label: "NCBI Bibliography", href: frontmatter.links.ncbi } : null,
  frontmatter.links?.bluesky ? { label: "Bluesky", href: frontmatter.links.bluesky } : null,
  frontmatter.links?.twitter ? { label: "X (Twitter)", href: frontmatter.links.twitter } : null,
].filter(Boolean) as Array<{ label: string; href: string }>;
---

<Layout
  title={`${frontmatter.name} | ${frontmatter.title}`}
  description={`${frontmatter.name}, ${frontmatter.title} at Weill Cornell Medicine. PI of the Grosenick Lab.`}
>
  <PageHeader
    eyebrow="Principal Investigator"
    title={frontmatter.name}
    lead={frontmatter.title}
  />

  <div class="mx-auto max-w-[1120px] px-7 py-16">
    <div class="grid gap-12 md:grid-cols-[280px_1fr]">
      <aside class="space-y-7">
        <div
          class="aspect-square rounded-[14px] overflow-hidden bg-wash border border-line flex items-center justify-center"
        >
          {
            showPhoto ? (
              <img
                src={frontmatter.photo}
                alt={frontmatter.name}
                class="w-full h-full object-cover"
              />
            ) : (
              <span class="font-display font-bold text-[56px] text-faint">
                {initials}
              </span>
            )
          }
        </div>

        <div>
          <p
            class="font-mono text-[11px] uppercase tracking-wide text-faint m-0 mb-2"
          >
            Contact
          </p>
          <a
            href={`mailto:${frontmatter.email}`}
            class="text-sm text-signal-ink font-medium no-underline hover:underline break-all"
          >
            {frontmatter.email}
          </a>
        </div>

        {
          linkRows.length > 0 && (
            <div>
              <p class="font-mono text-[11px] uppercase tracking-wide text-faint m-0 mb-2">
                Links
              </p>
              <ul class="list-none m-0 p-0 space-y-1">
                {linkRows.map((l) => (
                  <li>
                    <a
                      href={l.href}
                      class="text-sm text-signal-ink font-medium no-underline hover:underline"
                    >
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <div>
          <p
            class="font-mono text-[11px] uppercase tracking-wide text-faint m-0 mb-2"
          >
            Training
          </p>
          <ul class="list-none m-0 p-0 space-y-2.5">
            {
              (frontmatter.training as string[]).map((t: string) => (
                <li class="text-[13.5px] text-muted leading-relaxed">{t}</li>
              ))
            }
          </ul>
        </div>

        <div>
          <p
            class="font-mono text-[11px] uppercase tracking-wide text-faint m-0 mb-2"
          >
            Affiliations
          </p>
          <ul class="list-none m-0 p-0 space-y-1.5">
            {
              (frontmatter.affiliations as string[]).map((a: string) => (
                <li class="text-[13.5px] text-muted leading-relaxed">{a}</li>
              ))
            }
          </ul>
        </div>
      </aside>

      <article class="prose-page">
        <Content />
      </article>
    </div>
  </div>
</Layout>
