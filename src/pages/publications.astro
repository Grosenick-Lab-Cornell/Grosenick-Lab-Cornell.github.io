---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import PubList from "@/components/PubList.astro";
---

<Layout
  title="Publications | Grosenick Lab"
  description="Lab publications grouped by year, with paper / arXiv / code links and bolded lab authors."
>
  <PageHeader
    eyebrow="Publications"
    title="All papers, by year."
    lead="Lab member names are bolded. Links go to the paper, preprint, and code where they exist."
  />

  <div class="mx-auto max-w-[1120px] px-7 py-12">
    <PubList />
  </div>
</Layout>
