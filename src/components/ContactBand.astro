---
import siteConfig from "@/content/site.yaml";

const { email, github, bluesky, twitter } = siteConfig.contact;
---

<section class="border-t border-line py-20">
  <div class="mx-auto max-w-[1120px] px-7">
    <p
      class="font-mono text-xs uppercase tracking-[0.16em] text-signal-ink m-0 mb-3"
    >
      Get in touch
    </p>
    <h2
      class="font-display text-3xl md:text-[34px] font-medium tracking-[-0.015em] m-0 mb-5 max-w-[28ch]"
    >
      Interested in joining the lab or collaborating?
    </h2>
    <p class="text-[19px] text-muted max-w-[58ch] m-0 mb-8">
      We're open to postdocs, students, and collaborators excited about machine
      learning, neuroengineering, and precision psychiatry. The fastest way to
      reach us is email.
    </p>
    <div class="flex flex-wrap items-center gap-x-7 gap-y-4">
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-ink text-paper font-display font-medium text-sm no-underline hover:bg-signal-ink transition-colors"
      >
        {email}
      </a>
      <div class="flex gap-6">
        {
          github && (
            <a
              href={github}
              class="text-sm font-display font-medium text-muted hover:text-ink no-underline"
            >
              GitHub
            </a>
          )
        }
        {
          bluesky && (
            <a
              href={bluesky}
              class="text-sm font-display font-medium text-muted hover:text-ink no-underline"
            >
              Bluesky
            </a>
          )
        }
        {
          twitter && (
            <a
              href={twitter}
              class="text-sm font-display font-medium text-muted hover:text-ink no-underline"
            >
              X
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>
