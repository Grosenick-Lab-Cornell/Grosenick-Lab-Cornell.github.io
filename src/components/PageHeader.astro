---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<header class="pt-16 pb-12 border-b border-line">
  <div class="mx-auto max-w-[1120px] px-7">
    {
      eyebrow && (
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-signal-ink m-0 mb-3">
          {eyebrow}
        </p>
      )
    }
    <h1
      class="font-display text-4xl md:text-5xl font-medium tracking-[-0.015em] m-0 mb-5 max-w-[32ch]"
    >
      {title}
    </h1>
    {
      lead && (
        <p class="text-[19px] text-muted max-w-[62ch] m-0 leading-[1.55]">
          {lead}
        </p>
      )
    }
  </div>
</header>
